pnpm-lock.yaml

# Build output (tsc outDir, see tsconfig.json) + npm pack tarballs
dist/
*.tsbuildinfo
*.tgz

# Secrets — never commit
.env
.env.*
!.env.example

# Logs
*.log

# OS / editor
.DS_Store
.vscode/
.idea/

# Internal planning notes (owner policy: local-only, untracked)
.planning/
